{
  "name": "dragones-y-pedrulos-server",
  "version": "1.0.0",
  "description": "Backend para Dragones&Pedrulos",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "start": "concurrently \"npm run server\" \"npm run client\" --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\""
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}